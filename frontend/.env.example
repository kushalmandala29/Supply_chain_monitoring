# Vite loads .env from this directory (frontend/), not the repo root -- copy
# this to frontend/.env when running the frontend natively.

VITE_GATEWAY_WS_URL=ws://localhost:8000/ws
VITE_GATEWAY_HTTP_URL=http://localhost:8000

# CARTO's Dark Matter style: free, no API key required, dark basemap for the
# Jarvis HUD aesthetic. Alternatives: OpenFreeMap (https://openfreemap.org,
# also free/no-key) styles liberty/bright/positron are lighter/more colorful.
VITE_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
