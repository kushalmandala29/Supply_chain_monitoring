# Vite loads .env from this directory (frontend/), not the repo root -- copy
# this to frontend/.env when running the frontend natively.
#
# Use localhost, not a LAN/WSL IP -- those change across reboots/network
# switches and will silently break the WebSocket/REST connection (browser
# devtools will show ERR_CONNECTION_TIMED_OUT, not an obvious "wrong host"
# error). Only use a real LAN IP here if you specifically need to reach the
# dev server from a second device.

VITE_GATEWAY_WS_URL=ws://localhost:8010/ws
VITE_GATEWAY_HTTP_URL=http://localhost:8010

# Optional: override the 3D globe's textures (defaults to three-globe's
# standard dark-Earth/bump/star-field assets, no API key required).
# VITE_GLOBE_IMAGE_URL=
# VITE_GLOBE_BUMP_URL=
# VITE_GLOBE_BACKGROUND_URL=
