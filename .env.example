# Local dev config. The backend gateway, every agent, and the ETL pipelines
# all resolve this file explicitly by its repo-root path (see each service's
# config.py), so this one file is read no matter which directory you launch
# a service from -- you don't need a separate copy per service.
#
# The localhost connection defaults already match docker-compose.yml's
# passwords, so for plain local dev you'd only need this file at all for the
# external API keys below.

# --- Redis (shared blackboard) ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j (supply-chain graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- PostgreSQL / PostGIS ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supply_chain
POSTGRES_USER=supply_chain
POSTGRES_PASSWORD=change-me

# --- FastAPI gateway ---
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
JWT_SECRET=change-me
CORS_ORIGINS=http://localhost:5173

# --- External data providers (used by ETL pipelines, no hardcoded fallbacks) ---
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
RELIEFWEB_BASE_URL=https://api.reliefweb.int/v1
WEATHER_API_KEY=
WEATHER_API_BASE_URL=
COMMODITY_API_KEY=
COMMODITY_API_BASE_URL=
# NASA GIBS serves imagery tiles (WMTS/WMS) publicly, no API key required.
NASA_GIBS_BASE_URL=https://gibs.earthdata.nasa.gov/wmts/epsg4326/best

# --- Supervisor Agent: LLM synthesis via OpenRouter ---
# Web search itself is a DuckDuckGo HTML scrape -- no key/config needed.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Very low-cost paid model. You can switch to a :free model, but free models
# often have tighter rate limits / availability.
OPENROUTER_MODEL=nex-agi/nex-n2-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Jarvis Supply Chain Intelligence
