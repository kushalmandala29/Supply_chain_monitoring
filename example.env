# ============================================================================
# Multi-Agent Supply Chain Risk Intelligence System — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in your actual credentials.
# NEVER commit the .env file to version control.
# ============================================================================

# --- LLM Providers -----------------------------------------------------------

# Z.AI API (GLM-5.2 / GLM-4.6)
ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_API_KEY==
ZAI_DEFAULT_MODEL=glm-5.2
ZAI_FAST_MODEL=glm-4.6

# Google Gemini API (1.5 Flash / 1.5 Pro)
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# --- MCP Server Keys ---------------------------------------------------------

# Firecrawl MCP (Web-to-Markdown)
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Scrape.do MCP (Anti-Bot Proxy)
SCRAPEDO_API_TOKEN=

# --- Database Connections -----------------------------------------------------

# PostgreSQL / PostGIS (Persistent Analytics Memory)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=risk_intelligence
POSTGRES_USER=db_orchestrator
POSTGRES_PASSWORD=localdev123

# PostgreSQL Shadow DB (What-If Sandbox — same host, different schema)
SHADOW_DB_SCHEMA=shadow_whatif

# Amazon DynamoDB (Ephemeral State Memory)
DYNAMODB_TABLE_NAME=supply-chain-swarm-memory
DYNAMODB_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Neo4j AuraDB (Relational Topology Memory)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdev123

# --- AWS Infrastructure ------------------------------------------------------

# SQS Task Queue
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account/supply-chain-swarm-tasks.fifo

# --- Application Settings ----------------------------------------------------

# FastAPI Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# WebSocket
WS_PING_INTERVAL_SECONDS=600
WS_IDLE_TIMEOUT_SECONDS=7200

# Agent Configuration
DEBATE_MAX_ITERATIONS=3
ZSCORE_ANOMALY_THRESHOLD=2.5

# --- Spatial Engine -----------------------------------------------------------

GEO_CACHE_DIR=/var/cache/spatial_geojson
SPATIAL_ENGINE_PRECISION=high
